# --- Telegram ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=123456:replace-me

# --- Database ---
# SQLite (default) or PostgreSQL, e.g. postgresql+asyncpg://user:pass@host:5432/db
DATABASE_URL=sqlite+aiosqlite:///./data/887assistant.db

# --- File storage ---
FILE_STORAGE_PATH=./storage
# Max bytes the bot will download to local storage (else only the Telegram file_id is kept).
# Telegram bots can download files up to ~20 MB via getFile.
FILE_MAX_DOWNLOAD_BYTES=20971520

# --- LLM / AI chat ---
# Provider: moonshot | openrouter | gemini | groq | openai_compatible
LLM_PROVIDER=moonshot
LLM_API_KEY=
# Leave empty to use the provider default model.
LLM_MODEL=
# Optional override of the OpenAI-compatible base URL (for openai_compatible provider).
LLM_BASE_URL=
LLM_MAX_HISTORY_MESSAGES=20
LLM_REQUEST_TIMEOUT=60

# --- FACEIT ---
# Server-side API key from https://developers.faceit.com (App Studio -> API Keys)
FACEIT_API_KEY=
# Requests per second budget for the FACEIT client (be conservative, respect ToS).
FACEIT_RATE_LIMIT_RPS=4
# Cache TTL (seconds) for nickname lookups.
FACEIT_CACHE_TTL=600

# --- Calendar sync (.ics / webcal feed) ---
# Public base URL where the .ics web server is reachable (used to build webcal links).
BASE_URL=http://localhost:8080
# aiohttp web server bind config
WEB_HOST=0.0.0.0
WEB_PORT=8080

# --- Optional: Google Calendar two-way sync (not required) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# --- Misc ---
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=UTC
