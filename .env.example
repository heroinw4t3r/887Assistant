# --- Telegram ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=123456:replace-me

# --- Database ---
# SQLite (default) or PostgreSQL, e.g. postgresql+asyncpg://user:pass@host:5432/db
# Railway Postgres hands out a postgresql://... URL; the app auto-normalizes it
# to postgresql+asyncpg://... for the async engine, so you can paste it verbatim.
DATABASE_URL=sqlite+aiosqlite:///./data/887assistant.db

# --- File storage ---
FILE_STORAGE_PATH=./storage
# Max bytes the bot will download to local storage (else only the Telegram file_id is kept).
# Telegram bots can download files up to ~20 MB via getFile.
FILE_MAX_DOWNLOAD_BYTES=20971520
# Per-user storage quota in bytes; 0 = unlimited.
FILE_STORAGE_QUOTA_BYTES=524288000

# --- Object storage (S3 / Cloudflare R2) ---
# Backend for stored file blobs: local (default) | s3
STORAGE_BACKEND=local
# For Cloudflare R2 set STORAGE_BACKEND=s3 and fill in the values below:
#   S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
#   S3_REGION=auto   (Cloudflare R2 expects "auto")
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=auto
# Optional: public base URL for serving file links (e.g. an R2 public bucket / CDN domain).
S3_PUBLIC_BASE_URL=

# --- LLM / AI chat ---
# Provider: moonshot | openrouter | gemini | groq | openai_compatible
LLM_PROVIDER=openrouter
LLM_API_KEY=
# Leave empty to use the provider default model.
# OpenRouter default: meta-llama/llama-3.3-70b-instruct:free
LLM_MODEL=
# Optional override of the OpenAI-compatible base URL (for openai_compatible provider).
LLM_BASE_URL=
LLM_MAX_HISTORY_MESSAGES=50
LLM_REQUEST_TIMEOUT=60

# --- AI web search ---
# Enable a web lookup before answering in AI chat (toggle in chat keyboard).
WEB_SEARCH_ENABLED=true
# Provider: tavily (recommended; needs TAVILY_API_KEY) | duckduckgo (free, no key).
# DuckDuckGo is unreliable from datacenter/hosting IPs and may time out, so Tavily
# is recommended for hosted deployments.
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_MAX_RESULTS=5
TAVILY_API_KEY=

# --- FACEIT ---
# Server-side API key from https://developers.faceit.com (App Studio -> API Keys)
FACEIT_API_KEY=
# Requests per second budget for the FACEIT client (be conservative, respect ToS).
FACEIT_RATE_LIMIT_RPS=10
# Cache TTL (seconds) for nickname lookups.
FACEIT_CACHE_TTL=86400

# --- Calendar sync (.ics / webcal feed) ---
# Public base URL where the .ics web server is reachable (used to build webcal links).
BASE_URL=http://localhost:8080
# aiohttp web server bind config
WEB_HOST=0.0.0.0
WEB_PORT=8080

# --- Optional: Google Calendar two-way sync (not required) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# --- Misc ---
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=UTC
